# Copy to .env and adjust as needed:  cp .env.example .env

# ---- Primary store (Postgres = source of truth) ----
PG_HOST=localhost
PG_PORT=5433               # 5433 to avoid clashing with a native Postgres on 5432
PG_USER=typeahead
PG_PASSWORD=typeahead
PG_DB=typeahead

# ---- Distributed cache (3 Redis nodes, routed by consistent hashing) ----
# host:port for each logical cache node. The app hashes prefix -> node.
CACHE_NODES=localhost:6390,localhost:6391,localhost:6392
VNODES=150                 # virtual nodes per physical node (ring balance)

# ---- Cache invalidation (TTL is the primary mechanism; see DESIGN.md) ----
TTL_SUGGEST=45             # seconds; suggestions shift slowly
TTL_TREND=8                # seconds; trending shifts fast -> shorter TTL
TTL_JITTER=0.2             # +/- fraction of TTL, anti-stampede

# ---- Batch writes (write-back buffer: flush on size OR time) ----
BATCH_SIZE_N=500
FLUSH_INTERVAL_T=1.0       # seconds

# ---- Suggestions / trie ----
TOP_K=10
PRECOMPUTE_PREFIX_LEN=3    # eagerly precompute top-k for prefixes <= this length
TRIE_REFRESH_SEC=120       # periodic pool refresh + decay correction

# ---- Ranking (basic vs trending) ----
RANKING_MODE=hybrid        # count | hybrid  (default for /suggest if not overridden)
W_POP=1.0                  # weight on log(all-time count)
W_REC=2.0                  # weight on decayed recent_score
DECAY_HALFLIFE_SEC=3600    # recency half-life (1 hour)
